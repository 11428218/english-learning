# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=duolingual
DB_USER=postgres
DB_PASSWORD="DuoLingual_PG_2026!9fQ7#Lm2"

# Cloud DB URL (preferred in production platforms like Render/Railway/Supabase/Neon)
# If DATABASE_URL is set, host/port/user/password values above are ignored.
DATABASE_URL=
DB_SSL=false

# JWT
JWT_SECRET=your-secret-key-here-change-in-production

# Local AI (no external API required)
# CRAWLER_USER_AGENT is optional and used when crawling public pages.
CRAWLER_USER_AGENT=duolingual-local-ai-bot/1.0

# Offline dictionary import (optional)
# DICTIONARY_FILE can be a JSONL, CSV, or JSON array file.
# DICTIONARY_INSERT_MISSING=false updates existing words only.
DICTIONARY_FILE=backend/data/offline-dictionary.sample.jsonl
DICTIONARY_BATCH_SIZE=1000
DICTIONARY_INSERT_MISSING=false

# Server
PORT=5000
STRICT_PORT=true
REQUEST_TIMEOUT_MS=20000
NODE_ENV=development

# Database pool and query stability
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT_MS=10000

# Review assignment throttling (ms)
ASSIGNMENT_REFRESH_MS=120000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated list for multiple frontends (ex: production + preview)
FRONTEND_URLS=

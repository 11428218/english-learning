{
  "name": "duolingual-backend",
  "version": "1.0.0",
  "description": "Backend for language learning app with spaced repetition and AI",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:init": "ts-node src/db/init.ts",
    "db:seed": "ts-node src/db/seed.ts",
    "db:import:english": "ts-node src/db/importEnglishWords.ts",
    "db:import:dictionary": "ts-node src/db/importOfflineDictionary.ts",
    "db:build:wordnet": "ts-node src/db/buildWordNetDataset.ts",
    "db:import:wordnet": "ts-node src/db/importWordNetStructured.ts",
    "db:cleanup:dictionary": "ts-node src/db/cleanupDictionary.ts"
  },
  "keywords": [
    "language-learning",
    "flashcards",
    "spaced-repetition"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.8.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.10.0",
    "wordnet-db": "^3.1.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.11.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
